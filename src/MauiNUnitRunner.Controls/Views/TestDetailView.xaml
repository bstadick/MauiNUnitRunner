<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:MauiNUnitRunner.Controls.Views"
             xmlns:models="clr-namespace:MauiNUnitRunner.Controls.Models"
             x:Class="MauiNUnitRunner.Controls.Views.TestDetailView">

    <ContentView.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/TestControlResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
        <models:InverseBoolConverter x:Key="InverseBoolConverter"/>
        <models:ButtonDisabledStyleConverter x:Key="ButtonDisabledStyleConverter"/>
    </ContentView.Resources>

    <!-- ReSharper disable once Xaml.XamlXamarinFormsDataTypeAndBindingContextTypeMismatchedHighlighting -->
    <Grid Padding="10"
          BindingContext="{Binding Source={RelativeSource AncestorType={x:Type views:TestDetailView}}, x:DataType={x:Type views:TestDetailView}}"
          x:DataType="views:TestDetailView">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Display a detailed view of a single leaf node test (no child tests) -->
        <StackLayout Grid.Row="0">
            <Label Text="{Binding Test.FullDisplayName, FallbackValue='Test name'}"
                   Style="{StaticResource LabelTextStyle}" />
            <StackLayout Orientation="Horizontal">
                <Button Text="{StaticResource RunTestsButton}"
                        Style="{Binding TestRunState.IsTestRunning, FallbackValue={StaticResource ButtonStyle}, Converter={StaticResource ButtonDisabledStyleConverter}}"
                        Clicked="RunTestsButton_OnClicked" />
                <Button Text="{StaticResource SaveResultsButton}"
                        Style="{Binding TestRunState.IsTestRunning, FallbackValue={StaticResource ButtonStyle}, Converter={StaticResource ButtonDisabledStyleConverter}}"
                        Clicked="SaveResultsButton_OnClicked" />
            </StackLayout>
        </StackLayout>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <!-- Test result information -->
            <StackLayout Grid.Row="0" Orientation="Horizontal">
                <Label Text="{StaticResource TestsPageTestId}"
                       Style="{StaticResource LabelSubTextStyle}" />
                <Label Text="{Binding Test.Id, FallbackValue='-'}"
                       Style="{StaticResource LabelSubTextStyle}" />

                <Label Text="{StaticResource TestsPageTestDuration}"
                       Style="{StaticResource LabelSubTextStyle}"
                       IsVisible="{Binding Test.Result.HasTestResult, FallbackValue=false}" />
                <Label Text="{Binding Test.Result.DurationString, FallbackValue='-'}"
                       Style="{StaticResource LabelSubTextStyle}"
                       IsVisible="{Binding Test.Result.HasTestResult, FallbackValue=false}" />

                <Label Text="{StaticResource TestsPageTestAssertionCount}"
                       Style="{StaticResource LabelSubTextStyle}"
                       IsVisible="{Binding Test.Result.HasTestResult, FallbackValue=false}" />
                <Label Text="{Binding Test.Result.Result.AssertCount, FallbackValue='-'}"
                       Style="{StaticResource LabelSubTextStyle}"
                       IsVisible="{Binding Test.Result.HasTestResult, FallbackValue=false}" />
            </StackLayout>

            <!-- Test result status -->
            <StackLayout Grid.Row="1" Orientation="Horizontal">
                <Label Text="{StaticResource TestsPageTestResult}"
                       Style="{StaticResource LabelTextStyle}" />
                <Label Text="{Binding Test.Result.ResultStateStatus, FallbackValue={StaticResource TestResultNotExecuted}}"
                       Style="{StaticResource LabelTextStyle}"
                       TextColor="{Binding Test.Result.TextColor, FallbackValue=Gray}" />
            </StackLayout>

            <!-- Test result details -->
            <ScrollView Grid.Row="2">
                <StackLayout>
                    <Label Text="{Binding Test.Result.FailedAssertionsString, FallbackValue='Test message'}"
                           Style="{StaticResource LabelMultiLineTextStyle}"
                           IsVisible="{Binding Test.Result.HasFailedAssertions, FallbackValue=false}"
                           Padding="10" />

                    <Label Text="{StaticResource TestsPageTestOutput}"
                           Style="{StaticResource LabelSubTextStyle}"
                           IsVisible="{Binding Test.Result.HasOutput, FallbackValue=false}" />
                    <Label Text="{Binding Test.Result.Result.Output, FallbackValue='Test message'}"
                           Style="{StaticResource LabelMultiLineTextStyle}"
                           IsVisible="{Binding Test.Result.HasOutput, FallbackValue=false}"
                           Padding="10" />

                    <Label Text="{StaticResource TestsPageTestException}"
                           Style="{StaticResource LabelSubTextStyle}"
                           IsVisible="{Binding Test.Result.HasMessage, FallbackValue=false}" />
                    <Label Text="{Binding Test.Result.Result.Message, FallbackValue='Test message'}"
                           Style="{StaticResource LabelMultiLineTextStyle}"
                           IsVisible="{Binding Test.Result.HasMessage, FallbackValue=false}"
                           Padding="10" />

                    <Label Text="{StaticResource TestsPageTestStackTrace}"
                           Style="{StaticResource LabelSubTextStyle}"
                           IsVisible="{Binding Test.Result.HasStackTrace, FallbackValue=false}" />
                    <Label Text="{Binding Test.Result.Result.StackTrace, FallbackValue='Test message'}"
                           Style="{StaticResource LabelMultiLineTextStyle}"
                           IsVisible="{Binding Test.Result.HasStackTrace, FallbackValue=false}"
                           Padding="10" />
                </StackLayout>
            </ScrollView>
        </Grid>
    </Grid>
</ContentView>
